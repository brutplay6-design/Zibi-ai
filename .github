name: Zibi Bot Server

on:
  push:
    branches: [ main ]
  schedule:
    - cron: '0 */6 * * *' # Repornește botul la fiecare 6 ore ca să nu expire

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v3

    - name: Set up Python
      uses: actions/setup-python@v4
      with:
        python-version: '3.10'

    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install -r requirements.txt

    - name: Run Zibi Bot
      env:
        PYTHONUNBUFFERED: 1
      run: python zibi.py
